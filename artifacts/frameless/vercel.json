{
  "buildCommand": "pnpm --filter frameless run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "rewrites": [
    { 
      "source": "/api/:path*", 
      "destination": "https://frameless-super-app-api-server.vercel.app/api/:path*" 
    },
    { 
      "source": "/:path*", 
      "destination": "/index.html" 
    }
  ]
}